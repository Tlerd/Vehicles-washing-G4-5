# Copy to Back-end/.env (gitignored) and fill in real values.
# Loaded automatically by run-local.ps1 — never commit the real .env file.

# SQL Server 'sa' password for the local autowash_pro instance.
DB_PASSWORD=

# HMAC signing secret for JWT access tokens. If left blank, run-local.ps1
# generates one on first run and persists it back into .env.
JWT_SECRET=

# payOS (VietQR PRO) — Phase 3. Rotate any value that was ever pasted in chat
# or a screenshot before using it here.
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
